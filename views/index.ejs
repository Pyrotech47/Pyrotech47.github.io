<%- include('partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>
  <div class="hero-content">
    <div class="hero-badge">Available for Opportunities</div>
    <h1 class="hero-title">
      Michael <span class="accent">Baxter</span>
    </h1>
    <h2 class="hero-subtitle">Technical Designer</h2>
    <p class="hero-description">
      Canadore College Game Design &amp; Development graduate crafting
      immersive game mechanics through Unreal Engine 5's Blueprint
      Visual Scripting system. Turning design vision into playable reality.
    </p>
    <div class="hero-cta">
      <a href="/projects" class="btn btn-primary">View My Work</a>
      <a href="#contact" class="btn btn-secondary">Get In Touch</a>
    </div>
    <div class="hero-tags">
      <span class="tag">UE5 Blueprints</span>
      <span class="tag">Game Mechanics</span>
      <span class="tag">Technical Design</span>
      <span class="tag">Canadore College</span>
    </div>
  </div>
  <div class="hero-scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ABOUT -->
<section class="section about" id="about">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// About Me</span>
      <h2 class="section-title">Who I Am</h2>
    </div>
    <div class="about-grid">
      <div class="about-text">
        <p>
          I'm a recent graduate of Canadore College's Game Design &amp; Development
          Advanced Diploma program, where I developed a deep passion for the technical
          side of game creation — specifically the intersection of design thinking and
          systems implementation.
        </p>
        <p>
          As a <strong>Technical Designer</strong>, I bridge the gap between creative vision
          and functional gameplay. My primary tool is <strong>Unreal Engine 5's Blueprint
          Visual Scripting system</strong>, which I've used to architect complex game mechanics,
          AI behaviours, UI frameworks, and interactive world systems — all without the barrier
          of traditional programming languages.
        </p>
        <p>
          I believe great game feel comes from thoughtful systems design, and I'm eager to
          bring that philosophy to a team where I can grow as a professional.
        </p>
        <div class="about-details">
          <div class="detail">
            <span class="detail-label">Education</span>
            <span class="detail-value">Canadore College — Game Design &amp; Development (Advanced Diploma)</span>
          </div>
          <div class="detail">
            <span class="detail-label">Specialization</span>
            <span class="detail-value">Technical Design · Unreal Engine 5</span>
          </div>
          <div class="detail">
            <span class="detail-label">Location</span>
            <span class="detail-value">North Bay, Ontario, Canada</span>
          </div>
        </div>
      </div>
      <div class="about-visual">
        <div class="ue5-card">
          <div class="ue5-card-header">
            <span class="ue5-dot red"></span>
            <span class="ue5-dot yellow"></span>
            <span class="ue5-dot green"></span>
            <span class="ue5-card-title">Blueprint Graph</span>
          </div>
          <div class="ue5-card-body">
            <div class="bp-node event">
              <span class="bp-node-icon">⚡</span>
              <span>Event BeginPlay</span>
            </div>
            <div class="bp-connector"></div>
            <div class="bp-node function">
              <span class="bp-node-icon">⚙</span>
              <span>Initialize Systems</span>
            </div>
            <div class="bp-connector"></div>
            <div class="bp-node branch">
              <span class="bp-node-icon">◈</span>
              <span>Branch</span>
            </div>
            <div class="bp-row">
              <div class="bp-node pure green-node">
                <span>True → Spawn Actor</span>
              </div>
              <div class="bp-node pure red-node">
                <span>False → Log Warning</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section class="section skills" id="skills">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// Skills</span>
      <h2 class="section-title">Core Competencies</h2>
    </div>
    <div class="skills-grid">

      <div class="skill-card" data-aos="fade-up">
        <div class="skill-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>Blueprint Visual Scripting</h3>
        <div class="skill-bar"><div class="skill-fill" data-width="92"></div></div>
        <p>
          Advanced proficiency in UE5 Blueprints — from simple actor logic to complex
          multi-system architectures using interfaces, event dispatchers, and component-based design.
        </p>
      </div>

      <div class="skill-card" data-aos="fade-up" data-aos-delay="100">
        <div class="skill-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <h3>Game Mechanics Design</h3>
        <div class="skill-bar"><div class="skill-fill" data-width="88"></div></div>
        <p>
          Designing, prototyping, and iterating on gameplay systems — movement, combat, inventory,
          dialogue, and progression — with a focus on feel, balance, and player experience.
        </p>
      </div>

      <div class="skill-card" data-aos="fade-up" data-aos-delay="200">
        <div class="skill-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <h3>AI & Behavior Systems</h3>
        <div class="skill-bar"><div class="skill-fill" data-width="80"></div></div>
        <p>
          Implementing enemy and NPC AI using UE5's Behavior Tree editor, AI Perception System,
          Blackboards, and custom Blueprint-driven state machines.
        </p>
      </div>

      <div class="skill-card" data-aos="fade-up" data-aos-delay="300">
        <div class="skill-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h3>UI/UX with UMG</h3>
        <div class="skill-bar"><div class="skill-fill" data-width="85"></div></div>
        <p>
          Building polished, accessible game interfaces using Unreal Motion Graphics — HUDs,
          menus, settings screens, and interactive world widgets.
        </p>
      </div>

      <div class="skill-card" data-aos="fade-up" data-aos-delay="400">
        <div class="skill-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
          </svg>
        </div>
        <h3>Unreal Engine 5 Pipeline</h3>
        <div class="skill-bar"><div class="skill-fill" data-width="87"></div></div>
        <p>
          Hands-on experience with UE5's full feature set — Lumen, Nanite, World Partition,
          Sequencer, Enhanced Input, Data Assets, and Game Framework classes.
        </p>
      </div>

    </div>
  </div>
</section>

<!-- FEATURED PROJECTS -->
<section class="section featured-projects" id="projects">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// Featured Work</span>
      <h2 class="section-title">Selected Projects</h2>
    </div>
    <div class="featured-grid">
      <% featuredProjects.forEach((project, index) => { %>
      <article class="featured-card <%= index === 0 ? 'featured-card--large' : '' %>">
        <div class="featured-card-image">
          <div class="featured-card-placeholder">
            <span><%= project.title.charAt(0) %></span>
          </div>
          <div class="featured-card-overlay">
            <a href="/projects/<%= project.id %>" class="featured-card-cta">View Project</a>
          </div>
        </div>
        <div class="featured-card-body">
          <div class="featured-card-meta">
            <span class="card-category"><%= project.category %></span>
            <span class="card-year"><%= project.year %></span>
          </div>
          <h3 class="featured-card-title">
            <a href="/projects/<%= project.id %>"><%= project.title %></a>
          </h3>
          <p class="featured-card-desc"><%= project.shortDescription %></p>
          <div class="card-tags">
            <% project.tags.slice(0, 4).forEach(tag => { %>
            <span class="card-tag"><%= tag %></span>
            <% }) %>
          </div>
        </div>
      </article>
      <% }) %>
    </div>
    <div class="section-cta">
      <a href="/projects" class="btn btn-outline">View All Projects</a>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section contact" id="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-label">// Contact</span>
      <h2 class="section-title">Let's Work Together</h2>
      <p class="section-subtitle">
        I'm actively looking for Technical Designer roles. Whether you have an
        opportunity, a question, or just want to talk game design — I'd love to hear from you.
      </p>
    </div>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <strong>Location</strong>
            <span>North Bay, Ontario, Canada</span>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">🎓</div>
          <div>
            <strong>Education</strong>
            <span>Canadore College — Game Design &amp; Dev</span>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">🎮</div>
          <div>
            <strong>Specialization</strong>
            <span>UE5 · Blueprints · Technical Design</span>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">💼</div>
          <div>
            <strong>Status</strong>
            <span class="status-available">Open to Opportunities</span>
          </div>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <% if (typeof contactError !== 'undefined' && contactError) { %>
        <div class="form-alert form-alert--error">
          ⚠️ <%= contactError %>
        </div>
        <% } %>

        <form class="contact-form" action="/#contact" method="POST">
          <input type="hidden" name="_method" value="POST" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name <span class="required">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Jane Smith"
                value="<%= typeof formData !== 'undefined' ? formData.name || '' : '' %>"
                required
              />
            </div>
            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="jane@studio.com"
                value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
                required
              />
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="Technical Designer Opportunity"
              value="<%= typeof formData !== 'undefined' ? formData.subject || '' : '' %>"
            />
          </div>
          <div class="form-group">
            <label for="message">Message <span class="required">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="6"
              placeholder="Tell me about your project or opportunity..."
              required
            ><%= typeof formData !== 'undefined' ? formData.message || '' : '' %></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full">
            <span>Send Message</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/>
            </svg>
          </button>
        </form>

        <!-- Override form action to route correctly -->
        <script>
          document.querySelector('.contact-form').action = '/contact';
        </script>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>